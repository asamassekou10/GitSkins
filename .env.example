# ─── Database (Neon Postgres) ────────────────────────────────────────────────
# Your Neon connection string — copy from the Neon dashboard (no pgbouncer params needed)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ─── Auth (GitHub OAuth) ─────────────────────────────────────────────────────
# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ─── Auth (GitHub OAuth) ─────────────────────────────────────────────────────
# Create a GitHub OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#               https://yourdomain.com/api/auth/callback/github (prod)
AUTH_GITHUB_ID="your_github_oauth_app_client_id"
AUTH_GITHUB_SECRET="your_github_oauth_app_client_secret"

# Random secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# ─── GitHub API ──────────────────────────────────────────────────────────────
# Personal access token with read:user scope (for widget/profile data fetching)
# Create at https://github.com/settings/tokens
GITHUB_TOKEN="your_github_personal_access_token_here"

# ─── AI (Google Gemini) ──────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Optional: override default model names
# GEMINI_MODEL="gemini-2.5-flash"
# GEMINI_MODEL_PRO="gemini-2.5-pro"
# GEMINI_MODEL_FAST="gemini-2.5-flash"

# ─── Stripe Payments ─────────────────────────────────────────────────────────
# Create products/prices in your Stripe dashboard, then paste the price IDs here
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs from your Stripe dashboard
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_LIFETIME="price_..."
STRIPE_PRICE_CREDITS_50="price_..."
STRIPE_PRICE_CREDITS_150="price_..."

# ─── Email (Resend) — Optional ───────────────────────────────────────────────
# Sign up at https://resend.com, verify your domain, then paste the API key here.
# When not set, welcome and payment confirmation emails are silently skipped.
RESEND_API_KEY="re_..."

# ─── Analytics & Monitoring (Optional) ───────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_your_posthog_key_here"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

NEXT_PUBLIC_SENTRY_DSN="your_sentry_dsn_here"
SENTRY_AUTH_TOKEN="your_sentry_auth_token_here"

# ─── Rate Limiting via Vercel KV (Optional) ───────────────────────────────────
# Provision a KV store in your Vercel project dashboard
KV_REST_API_URL="https://..."
KV_REST_API_TOKEN="your_kv_token_here"

# ─── Waitlist Gating (Optional) ───────────────────────────────────────────────
# Set WAITLIST_ENABLED=true to gate the site; bypass with ?access=<secret>
WAITLIST_ENABLED=false
WAITLIST_SECRET="your_secret_key_here"
