{
  "manifest_version": 3,
  "name": "GitSkins",
  "description": "Bring GitSkins cards, avatars, README tools, and profile skins into GitHub.",
  "version": "0.1.0",
  "action": {
    "default_title": "GitSkins",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "clipboardWrite", "storage"],
  "host_permissions": ["https://github.com/*", "https://gitskins.com/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
